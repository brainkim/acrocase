{
  "name": "eslint-plugin-acrocase",
  "version": "0.0.1",
  "description": "ESLint plugin to enforce ACROCase naming conventions",
  "main": "src/index.js",
  "files": [
    "src",
    "dictionary.json"
  ],
  "scripts": {
    "develop": "shovel develop website/app.tsx --platform bun",
    "static": "MODE=production shovel build website/app.tsx --platform bun --lifecycle",
    "predeploy": "npm run static",
    "deploy": "gh-pages -d dist/public --nojekyll --cname acrocase.org",
    "preview": "bun run static && bunx serve dist/public"
  },
  "keywords": [
    "eslint",
    "eslintplugin",
    "eslint-plugin",
    "acrocase",
    "naming-convention",
    "acronyms"
  ],
  "author": "Brian Kim",
  "license": "MIT",
  "peerDependencies": {
    "eslint": ">=8.0.0"
  },
  "dependencies": {
    "@b9g/cache": "^0.2.2",
    "@b9g/crank": "^0.7.9",
    "@b9g/filesystem": "^0.1.11",
    "@b9g/router": "^0.2.5",
    "@b9g/shovel": "^0.2.19"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "gh-pages": "^6.3.0",
    "typescript": "^5.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/brainkim/acrocase"
  }
}
